    "settings_terms_service" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"Terms of Use"}},"es":{"stringUnit":{"state":"translated","value":"Términos de uso"}}}},
    "settings_terms_service_subtitle" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"Rules for using Shield and its verified export tools"}},"es":{"stringUnit":{"state":"translated","value":"Reglas de uso de Shield y sus herramientas de exportación verificada"}}}},
    "settings_unlock_premium" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"Unlock Shield Pro"}},"es":{"stringUnit":{"state":"translated","value":"Desbloquea Shield Pro"}}}},
    "settings_verified_export_body" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"Shield rasterizes secure PDF exports and checks for recoverable text, annotations, metadata, and OCR residue. You must still review every page and selected region before sharing."}},"es":{"stringUnit":{"state":"translated","value":"Shield rasteriza los PDF seguros y comprueba texto recuperable, anotaciones, metadatos y residuos OCR. Aun así, debes revisar cada página y zona seleccionada antes de compartir."}}}},
    "settings_verified_export_title" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"Verified output, human review"}},"es":{"stringUnit":{"state":"translated","value":"Salida verificada, revisión humana"}}}},
    "settings_version_value" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"Version %@"}},"es":{"stringUnit":{"state":"translated","value":"Versión %@"}}}},
    "settings_view_options" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"View options"}},"es":{"stringUnit":{"state":"translated","value":"Ver opciones"}}}},
    "settings_whats_new" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"What's new"}},"es":{"stringUnit":{"state":"translated","value":"Novedades"}}}},
    "settings_whats_new_intro" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"Highlights included in this release of Shield."}},"es":{"stringUnit":{"state":"translated","value":"Principales mejoras incluidas en esta versión de Shield."}}}},
    "settings_whats_new_subtitle" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"Release highlights and improvements"}},"es":{"stringUnit":{"state":"translated","value":"Mejoras y novedades de la versión"}}}},
    "settings_whats_new_item_1" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"On-device OCR suggestions with per-field evidence and confidence."}},"es":{"stringUnit":{"state":"translated","value":"Sugerencias OCR en el dispositivo con evidencia y confianza por campo."}}}},
    "settings_whats_new_item_2" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"Secure rasterized PDF export with residual-content verification."}},"es":{"stringUnit":{"state":"translated","value":"Exportación PDF rasterizada segura con verificación de contenido residual."}}}},
    "settings_whats_new_item_3" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"Encrypted local projects and a separately protected Vault."}},"es":{"stringUnit":{"state":"translated","value":"Proyectos locales cifrados y una Bóveda protegida por separado."}}}},
    "settings_whats_new_item_4" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"Cancelable multi-page import from camera, Photos, Files, and Share Sheet."}},"es":{"stringUnit":{"state":"translated","value":"Importación multipágina cancelable desde Cámara, Fotos, Archivos y Compartir."}}}},
    "settings_whats_new_item_5" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"Optional minimized iCloud index synchronization for Pro."}},"es":{"stringUnit":{"state":"translated","value":"Sincronización opcional del índice mínimo de iCloud para Pro."}}}},
    "settings_whats_new_item_6" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"Improved accessibility, iPad layout, keyboard control, and privacy shielding."}},"es":{"stringUnit":{"state":"translated","value":"Mejoras de accesibilidad, diseño para iPad, teclado y pantalla de privacidad."}}}},

    "settings_info_intro" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"Important information about Shield's purpose, limitations, and your responsibility when handling sensitive documents."}},"es":{"stringUnit":{"state":"translated","value":"Información importante sobre la finalidad y los límites de Shield, y tu responsabilidad al tratar documentos sensibles."}}}},
    "settings_info_scope_title" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"Purpose of Shield"}},"es":{"stringUnit":{"state":"translated","value":"Finalidad de Shield"}}}},
    "settings_info_scope_body" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"Shield helps you import, scan, review, mask, and export copies of documents. It is a document-privacy tool, not an identity verification service, records-management system, or guarantee that a recipient will accept an edited copy."}},"es":{"stringUnit":{"state":"translated","value":"Shield ayuda a importar, escanear, revisar, enmascarar y exportar copias de documentos. Es una herramienta de privacidad documental, no un servicio de verificación de identidad, un gestor documental ni una garantía de que el destinatario acepte una copia editada."}}}},
    "settings_info_detection_title" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"Automated detection"}},"es":{"stringUnit":{"state":"translated","value":"Detección automática"}}}},
    "settings_info_detection_body" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"OCR and sensitive-field suggestions can be incomplete or incorrect because of image quality, language, layout, handwriting, document variation, or software limitations. Suggestions are aids only. Review every page and add, move, or remove masks as needed."}},"es":{"stringUnit":{"state":"translated","value":"El OCR y las sugerencias de campos sensibles pueden ser incompletos o incorrectos por la calidad de imagen, el idioma, el diseño, la escritura, las variaciones documentales o las limitaciones del software. Son solo ayudas. Revisa cada página y añade, mueve o elimina máscaras cuando sea necesario."}}}},
    "settings_info_export_title" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"Verified export"}},"es":{"stringUnit":{"state":"translated","value":"Exportación verificada"}}}},
    "settings_info_export_body" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"A verified export means Shield's technical checks passed for the generated file. It does not mean every sensitive item was detected or selected, that the source is authentic, or that disclosure is legally permitted. Verification does not replace your final visual review."}},"es":{"stringUnit":{"state":"translated","value":"Una exportación verificada significa que el archivo generado superó las comprobaciones técnicas de Shield. No significa que se detectaran o seleccionaran todos los datos sensibles, que el original sea auténtico ni que su divulgación sea legal. La verificación no sustituye tu revisión visual final."}}}},
    "settings_info_security_title" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"Device security"}},"es":{"stringUnit":{"state":"translated","value":"Seguridad del dispositivo"}}}},
    "settings_info_security_body" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"Encryption and the Vault reduce exposure if app files are accessed, but protection also depends on your device passcode, operating-system security, backups, account security, and how you share exported files. No technical system can eliminate every risk."}},"es":{"stringUnit":{"state":"translated","value":"El cifrado y la Bóveda reducen la exposición si se accede a los archivos de la app, pero la protección también depende del código del dispositivo, el sistema operativo, las copias, la seguridad de tus cuentas y cómo compartes las exportaciones. Ningún sistema elimina todos los riesgos."}}}},
    "settings_info_health_title" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"No professional advice"}},"es":{"stringUnit":{"state":"translated","value":"Sin asesoramiento profesional"}}}},
    "settings_info_health_body" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"Shield does not provide legal, medical, financial, compliance, identity, cybersecurity, or records-retention advice. Obtain qualified advice when your use is regulated or high risk."}},"es":{"stringUnit":{"state":"translated","value":"Shield no presta asesoramiento jurídico, médico, financiero, normativo, de identidad, ciberseguridad ni conservación documental. Busca asesoramiento cualificado cuando el uso esté regulado o sea de alto riesgo."}}}},
    "settings_info_responsibility_title" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"Your responsibility"}},"es":{"stringUnit":{"state":"translated","value":"Tu responsabilidad"}}}},
    "settings_info_responsibility_body" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"Use only documents you are authorized to process, preserve required originals, verify the intended recipient and purpose, and inspect the final exported file before sending it. You are responsible for complying with applicable law and contractual duties."}},"es":{"stringUnit":{"state":"translated","value":"Usa solo documentos que estés autorizado a tratar, conserva los originales exigidos, verifica destinatario y finalidad, e inspecciona el archivo final antes de enviarlo. Eres responsable de cumplir la ley y las obligaciones contractuales aplicables."}}}},

    "settings_privacy_intro" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"This policy explains how Shield handles information when you use the app."}},"es":{"stringUnit":{"state":"translated","value":"Esta política explica cómo trata Shield la información cuando usas la app."}}}},
    "settings_privacy_controller_title" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"Who is responsible"}},"es":{"stringUnit":{"state":"translated","value":"Quién es responsable"}}}},
    "settings_privacy_controller_body" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"Shield is developed by Lester Romero Bernardo (RomeroDev), Calle Madre Juana María Condesa Lluch 6, Valencia, Spain. Privacy and support inquiries can be sent to romerodev.app+shield@gmail.com. The published privacy policy is available from Shield and the official support website. Apple independently processes App Store purchases and related account data under Apple's policies."}},"es":{"stringUnit":{"state":"translated","value":"Shield está desarrollada por Lester Romero Bernardo (RomeroDev), Calle Madre Juana María Condesa Lluch 6, Valencia, España. Las consultas de privacidad y soporte pueden enviarse a romerodev.app+shield@gmail.com. La política de privacidad publicada está disponible desde Shield y el sitio web oficial de soporte. Apple trata de forma independiente las compras y datos de cuenta del App Store conforme a sus políticas."}}}},
    "settings_privacy_processing_title" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"On-device processing"}},"es":{"stringUnit":{"state":"translated","value":"Procesamiento en el dispositivo"}}}},
    "settings_privacy_processing_body" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"Document import, camera capture, scanning, image adjustments, OCR, masking, and export are performed on your device. Shield does not operate an advertising or analytics backend, does not create advertising profiles, and does not track you across apps or websites."}},"es":{"stringUnit":{"state":"translated","value":"La importación, cámara, escaneo, ajustes de imagen, OCR, máscaras y exportación se realizan en tu dispositivo. Shield no opera un backend publicitario o analítico, no crea perfiles publicitarios ni te rastrea entre apps o sitios web."}}}},
    "settings_privacy_storage_title" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"Local storage and security"}},"es":{"stringUnit":{"state":"translated","value":"Almacenamiento local y seguridad"}}}},
    "settings_privacy_storage_body" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"Imported originals, working files, render caches, and local telemetry are encrypted at rest using device-bound keys protected by Keychain and iOS data protection. Vault content uses a separate device-bound key and requires your configured authentication. Keys marked device-only are not designed to migrate to another device."}},"es":{"stringUnit":{"state":"translated","value":"Los originales, archivos de trabajo, cachés y telemetría local se cifran en reposo con claves vinculadas al dispositivo, protegidas por Llavero y la protección de datos de iOS. La Bóveda usa otra clave y requiere la autenticación configurada. Las claves solo del dispositivo no están diseñadas para migrar."}}}},
    "settings_privacy_icloud_title" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"Optional complete iCloud backup"}},"es":{"stringUnit":{"state":"translated","value":"Copia completa opcional en iCloud"}}}},
    "settings_privacy_icloud_body" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"If a Pro user explicitly enables iCloud sync, Shield stores complete restorable document packages in that user's private CloudKit database. Private CKAssets are encrypted by CloudKit. Disabling sync deletes Shield's remote records."}},"es":{"stringUnit":{"state":"translated","value":"Si una persona Pro activa expresamente iCloud, Shield guarda paquetes completos y restaurables en su base privada de CloudKit. CloudKit cifra los CKAsset privados. Al desactivar la sincronización se eliminan los registros remotos de Shield."}}}},
    "settings_privacy_permissions_title" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"Permissions and Files providers"}},"es":{"stringUnit":{"state":"translated","value":"Permisos y proveedores de Archivos"}}}},
    "settings_privacy_permissions_body" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"Camera, Photos, biometric authentication, Files, Share Sheet, and iCloud access are used only for the features you request and subject to system permission controls. When you choose a third-party storage provider through Apple's Files picker, Shield receives only the file you select and stores no provider OAuth token."}},"es":{"stringUnit":{"state":"translated","value":"El acceso a Cámara, Fotos, biometría, Archivos, Compartir e iCloud se usa solo para las funciones que solicitas y bajo controles del sistema. Si eliges un proveedor mediante el selector Archivos de Apple, Shield recibe solo el archivo seleccionado y no guarda tokens OAuth del proveedor."}}}},
    "settings_privacy_diagnostics_title" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"Diagnostics"}},"es":{"stringUnit":{"state":"translated","value":"Diagnósticos"}}}},
    "settings_privacy_diagnostics_body" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"MetricKit diagnostics and bounded local telemetry may contain app versions, event identifiers, durations, counts, and device-class buckets. Shield does not upload them and excludes document titles, OCR text, filenames, URLs, document identifiers, PIN state, and image content."}},"es":{"stringUnit":{"state":"translated","value":"Los diagnósticos de MetricKit y la telemetría local limitada pueden incluir versiones, identificadores de evento, duraciones, recuentos y clases de dispositivo. Shield no los sube y excluye títulos, texto OCR, nombres de archivo, URL, identificadores, estado del PIN e imágenes."}}}},
    "settings_privacy_retention_title" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"Retention and deletion"}},"es":{"stringUnit":{"state":"translated","value":"Conservación y eliminación"}}}},
    "settings_privacy_retention_body" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"Projects remain until you delete them or use Delete all documents. Temporary exports are protected and removed when the export or share flow ends. Deleting the app removes its local data subject to iOS and backup behavior. Private CloudKit records can require separate deletion or iCloud account controls."}},"es":{"stringUnit":{"state":"translated","value":"Los proyectos permanecen hasta que los elimines o uses Eliminar todos. Las exportaciones temporales se protegen y borran al terminar el flujo. Desinstalar elimina datos locales según el funcionamiento de iOS y las copias. Los registros privados de CloudKit pueden requerir borrado separado o controles de iCloud."}}}},
    "settings_privacy_rights_title" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"Your choices and rights"}},"es":{"stringUnit":{"state":"translated","value":"Tus opciones y derechos"}}}},
    "settings_privacy_rights_body" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"You can deny or revoke optional permissions in iOS Settings, disable iCloud index sync, delete projects, and contact the developer about applicable privacy rights. Because core document content stays on device, the developer normally cannot access, export, correct, or recover it for you."}},"es":{"stringUnit":{"state":"translated","value":"Puedes denegar o revocar permisos en Ajustes de iOS, desactivar iCloud, borrar proyectos y contactar con el desarrollador sobre tus derechos. Como el contenido principal permanece en el dispositivo, el desarrollador normalmente no puede acceder, exportar, corregir ni recuperarlo por ti."}}}},
    "settings_privacy_children_title" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"Children"}},"es":{"stringUnit":{"state":"translated","value":"Menores"}}}},
    "settings_privacy_children_body" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"Shield is a general document utility and is not directed to children. Do not use it to process a child's sensitive information unless you have lawful authority and appropriate safeguards."}},"es":{"stringUnit":{"state":"translated","value":"Shield es una utilidad documental general y no está dirigida a menores. No la uses para tratar datos sensibles de un menor sin autoridad legal y salvaguardas adecuadas."}}}},
    "settings_privacy_changes_title" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"Policy changes"}},"es":{"stringUnit":{"state":"translated","value":"Cambios de la política"}}}},
    "settings_privacy_changes_body" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"This policy may be updated when Shield's features, providers, or legal obligations change. Material changes will be reflected by a new effective date and, when appropriate, an in-app notice."}},"es":{"stringUnit":{"state":"translated","value":"La política puede actualizarse cuando cambien las funciones, proveedores u obligaciones legales. Los cambios relevantes se reflejarán con una nueva fecha y, cuando proceda, un aviso en la app."}}}},

    "settings_terms_intro" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"These terms govern your use of Shield. Mandatory consumer rights in your country continue to apply."}},"es":{"stringUnit":{"state":"translated","value":"Estos términos rigen el uso de Shield. Se mantienen los derechos imperativos de consumidores de tu país."}}}},
    "settings_terms_acceptance_title" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"Acceptance and eligibility"}},"es":{"stringUnit":{"state":"translated","value":"Aceptación y capacidad"}}}},
    "settings_terms_acceptance_body" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"By downloading or using Shield, you agree to these terms and Apple's applicable App Store terms. You must be legally able to enter this agreement. If you use Shield for an organization, you confirm you have authority to bind it."}},"es":{"stringUnit":{"state":"translated","value":"Al descargar o usar Shield aceptas estos términos y los aplicables del App Store de Apple. Debes tener capacidad legal. Si la usas para una organización, confirmas que puedes vincularla."}}}},
    "settings_terms_license_title" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"License"}},"es":{"stringUnit":{"state":"translated","value":"Licencia"}}}},
    "settings_terms_license_body" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"You receive a limited, personal, non-exclusive, non-transferable, revocable license to use Shield on Apple devices associated with your App Store account, subject to these terms and Apple's usage rules. Shield is licensed, not sold."}},"es":{"stringUnit":{"state":"translated","value":"Recibes una licencia limitada, personal, no exclusiva, intransferible y revocable para usar Shield en dispositivos Apple asociados a tu cuenta, sujeta a estos términos y las reglas de Apple. Shield se licencia, no se vende."}}}},
    "settings_terms_user_content_title" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"Your documents"}},"es":{"stringUnit":{"state":"translated","value":"Tus documentos"}}}},
    "settings_terms_user_content_body" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"You retain your rights in documents and content you import or create. You confirm that you have the rights, consent, or other lawful basis needed to process them. Shield does not acquire ownership of your content."}},"es":{"stringUnit":{"state":"translated","value":"Conservas tus derechos sobre los documentos y contenido importado o creado. Confirmas que dispones de derechos, consentimiento o base jurídica para tratarlos. Shield no adquiere su propiedad."}}}},
    "settings_terms_permitted_title" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"Permitted use"}},"es":{"stringUnit":{"state":"translated","value":"Uso permitido"}}}},
    "settings_terms_permitted_body" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"Do not use Shield for fraud, impersonation, falsification, infringement, harassment, malware, unlawful surveillance, unauthorized disclosure, evasion of legal obligations, or interference with the app. Do not reverse engineer Shield except where applicable law expressly permits it."}},"es":{"stringUnit":{"state":"translated","value":"No uses Shield para fraude, suplantación, falsificación, infracción, acoso, malware, vigilancia ilícita, divulgación no autorizada, evasión de obligaciones ni interferencia con la app. No realices ingeniería inversa salvo permiso legal expreso."}}}},
    "settings_terms_accuracy_title" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"OCR and export limitations"}},"es":{"stringUnit":{"state":"translated","value":"Límites del OCR y la exportación"}}}},
    "settings_terms_accuracy_body" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"OCR, entity detection, masks, and technical verification can fail or produce false results. You must inspect every page and retain originals when required. Shield does not warrant acceptance by governments, banks, employers, healthcare providers, or other recipients."}},"es":{"stringUnit":{"state":"translated","value":"El OCR, la detección, las máscaras y la verificación técnica pueden fallar o dar resultados falsos. Debes inspeccionar cada página y conservar originales cuando sea exigible. Shield no garantiza aceptación por administraciones, bancos, empleadores, sanidad u otros destinatarios."}}}},
    "settings_terms_purchases_title" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"Purchases"}},"es":{"stringUnit":{"state":"translated","value":"Compras"}}}},
    "settings_terms_purchases_body" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"Pro products are sold through Apple's in-app purchase system. Prices, taxes, currency, eligibility, payment authorization, refunds, and account billing are controlled by Apple and the App Store storefront. Additional subscription conditions appear in Subscription terms."}},"es":{"stringUnit":{"state":"translated","value":"Los productos Pro se venden mediante compras integradas de Apple. Apple y la tienda controlan precios, impuestos, moneda, elegibilidad, autorización, reembolsos y facturación. Las condiciones adicionales figuran en Condiciones de suscripción."}}}},
    "settings_terms_ip_title" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"Intellectual property"}},"es":{"stringUnit":{"state":"translated","value":"Propiedad intelectual"}}}},
    "settings_terms_ip_body" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"Shield, its software, design, branding, documentation, and original content are protected by intellectual-property laws. Third-party frameworks, Apple services, and system symbols remain subject to their respective terms."}},"es":{"stringUnit":{"state":"translated","value":"Shield, su software, diseño, marca, documentación y contenido original están protegidos por normas de propiedad intelectual. Los frameworks, servicios de Apple y símbolos del sistema se rigen por sus condiciones."}}}},
    "settings_terms_liability_title" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"Availability and liability"}},"es":{"stringUnit":{"state":"translated","value":"Disponibilidad y responsabilidad"}}}},
    "settings_terms_liability_body" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"Shield is provided with the warranties required by applicable law. To the maximum extent legally permitted, it is otherwise provided as available, without guarantees of uninterrupted operation, perfect detection, fitness for a regulated purpose, or freedom from data loss. Liability is not excluded where law forbids exclusion."}},"es":{"stringUnit":{"state":"translated","value":"Shield se ofrece con las garantías exigidas por la ley. En la medida permitida, se presta según disponibilidad, sin garantía de funcionamiento ininterrumpido, detección perfecta, idoneidad regulada o ausencia de pérdida. No se excluye responsabilidad cuando la ley lo prohíbe."}}}},
    "settings_terms_termination_title" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"Suspension and termination"}},"es":{"stringUnit":{"state":"translated","value":"Suspensión y terminación"}}}},
    "settings_terms_termination_body" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"You may stop using Shield at any time. Access may be limited where necessary to protect users, comply with law, address misuse, or maintain services. Ending use does not automatically cancel an App Store subscription; manage it in your Apple account."}},"es":{"stringUnit":{"state":"translated","value":"Puedes dejar de usar Shield cuando quieras. El acceso puede limitarse para proteger usuarios, cumplir la ley, afrontar abusos o mantener servicios. Dejar de usarla no cancela una suscripción: gestiónala en tu cuenta Apple."}}}},
    "settings_terms_law_title" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"Governing terms and changes"}},"es":{"stringUnit":{"state":"translated","value":"Ley aplicable y cambios"}}}},
    "settings_terms_law_body" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"These terms are governed by Spanish law, including applicable consumer protections, and the competent courts of Valencia, without removing mandatory rights or courts available to consumers. Updated terms will show a new effective date; continued use after notice may constitute acceptance where permitted."}},"es":{"stringUnit":{"state":"translated","value":"Estos términos se rigen por la legislación española, incluida la protección aplicable a consumidores, y por los tribunales competentes de Valencia, sin eliminar derechos ni fueros imperativos. Los términos actualizados mostrarán una nueva fecha; el uso tras el aviso podrá implicar aceptación cuando sea legal."}}}},

    "settings_subscription_intro" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"These conditions supplement the Terms of Use for Shield Pro subscriptions and the lifetime unlock."}},"es":{"stringUnit":{"state":"translated","value":"Estas condiciones complementan los Términos de uso para las suscripciones Shield Pro y el desbloqueo vitalicio."}}}},
    "settings_subscription_products_title" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"Available products"}},"es":{"stringUnit":{"state":"translated","value":"Productos disponibles"}}}},
    "settings_subscription_products_body" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"Shield may offer monthly and annual auto-renewable subscriptions and a one-time lifetime unlock. The exact product, duration, current localized price, included features, and any offer are displayed by the App Store before purchase and take precedence over general examples."}},"es":{"stringUnit":{"state":"translated","value":"Shield puede ofrecer suscripciones mensuales y anuales autorrenovables y un desbloqueo vitalicio de pago único. El producto, duración, precio localizado, funciones y ofertas se muestran en el App Store antes de comprar y prevalecen sobre ejemplos generales."}}}},
    "settings_subscription_payment_title" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"Payment"}},"es":{"stringUnit":{"state":"translated","value":"Pago"}}}},
    "settings_subscription_payment_body" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"Payment is charged to your Apple Account when you confirm the purchase. Apple handles taxes, currency conversion, payment methods, and receipts. Shield does not receive your full payment-card details."}},"es":{"stringUnit":{"state":"translated","value":"El pago se carga en tu cuenta Apple al confirmarlo. Apple gestiona impuestos, conversión, métodos de pago y recibos. Shield no recibe los datos completos de tu tarjeta."}}}},
    "settings_subscription_renewal_title" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"Automatic renewal"}},"es":{"stringUnit":{"state":"translated","value":"Renovación automática"}}}},
    "settings_subscription_renewal_body" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"A subscription renews automatically for the same period unless you cancel it at least 24 hours before the current period ends. Apple may charge your account within 24 hours before renewal at the price shown for the next period, subject to Apple's notices and applicable law."}},"es":{"stringUnit":{"state":"translated","value":"La suscripción se renueva por el mismo periodo salvo cancelación al menos 24 horas antes de terminar. Apple puede cobrar dentro de las 24 horas previas al precio mostrado para el siguiente periodo, sujeto a sus avisos y la ley aplicable."}}}},
    "settings_subscription_trial_title" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"Trials and offers"}},"es":{"stringUnit":{"state":"translated","value":"Pruebas y ofertas"}}}},
    "settings_subscription_trial_body" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"Eligibility and duration for free trials, introductory offers, promotional offers, or win-back offers are determined by Apple and displayed before confirmation. Unless canceled before the offer ends, an eligible trial converts to the paid subscription shown. Any unused trial portion may be forfeited when purchasing another plan."}},"es":{"stringUnit":{"state":"translated","value":"Apple determina elegibilidad y duración de pruebas y ofertas, que se muestran antes de confirmar. Si no cancelas antes del final, una prueba elegible pasa a la suscripción de pago indicada. La parte no usada puede perderse al comprar otro plan."}}}},
    "settings_subscription_manage_title" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"Manage or cancel"}},"es":{"stringUnit":{"state":"translated","value":"Gestionar o cancelar"}}}},
    "settings_subscription_manage_body" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"Manage or cancel subscriptions in Settings > Apple Account > Subscriptions, or through the App Store subscription page. Deleting Shield does not cancel a subscription. Cancellation stops future renewal and access normally continues until the paid period ends."}},"es":{"stringUnit":{"state":"translated","value":"Gestiona o cancela en Ajustes > Cuenta Apple > Suscripciones o en la página de suscripciones del App Store. Eliminar Shield no cancela. La cancelación evita renovaciones y el acceso suele continuar hasta acabar el periodo pagado."}}}},
    "settings_subscription_restore_title" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"Restore purchases"}},"es":{"stringUnit":{"state":"translated","value":"Restaurar compras"}}}},
    "settings_subscription_restore_body" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"Use Restore purchases in Shield's purchase screen while signed in with the Apple Account that made the purchase. Restoration depends on App Store availability and verified StoreKit entitlements."}},"es":{"stringUnit":{"state":"translated","value":"Usa Restaurar compras en la pantalla de compra con la cuenta Apple que realizó la compra. Depende de la disponibilidad del App Store y de derechos StoreKit verificados."}}}},
    "settings_subscription_refunds_title" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"Refunds and billing issues"}},"es":{"stringUnit":{"state":"translated","value":"Reembolsos y problemas de cobro"}}}},
    "settings_subscription_refunds_body" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"Apple controls refund requests, billing disputes, grace periods, payment retries, and revocations under its policies and applicable law. Contact Apple for transaction-specific billing support. Mandatory refund and withdrawal rights remain unaffected."}},"es":{"stringUnit":{"state":"translated","value":"Apple controla reembolsos, disputas, periodos de gracia, reintentos y revocaciones según sus políticas y la ley. Contacta con Apple para cobros concretos. No se alteran derechos imperativos de reembolso o desistimiento."}}}},
    "settings_subscription_lifetime_title" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"Lifetime unlock"}},"es":{"stringUnit":{"state":"translated","value":"Desbloqueo vitalicio"}}}},
    "settings_subscription_lifetime_body" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"The lifetime unlock is a non-consumable purchase that grants the Pro features associated with that product for the supported lifetime of Shield, not the purchaser's biological lifetime. It does not promise future products, third-party services, team plans, or features that require separate ongoing costs."}},"es":{"stringUnit":{"state":"translated","value":"El desbloqueo vitalicio es una compra no consumible que concede las funciones Pro asociadas durante la vida útil soportada de Shield, no la vida biológica del comprador. No promete productos futuros, servicios de terceros, planes de equipo ni funciones con costes continuos separados."}}}},
    "settings_subscription_changes_title" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"Price and feature changes"}},"es":{"stringUnit":{"state":"translated","value":"Cambios de precio y funciones"}}}},
    "settings_subscription_changes_body" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"Apple and the developer may change future prices, plans, or included features. Apple provides required notices and consent flows for subscription price increases. Changes do not remove mandatory rights or entitlements already granted by a completed non-consumable purchase."}},"es":{"stringUnit":{"state":"translated","value":"Apple y el desarrollador pueden cambiar precios, planes o funciones futuras. Apple ofrece avisos y consentimientos exigidos para subidas. Los cambios no eliminan derechos imperativos ni derechos ya concedidos por una compra no consumible completada."}}}},

    "settings_faq_1_question" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"Does Shield upload my documents?"}},"es":{"stringUnit":{"state":"translated","value":"¿Shield sube mis documentos?"}}}},
    "settings_faq_1_answer" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"Processing remains on device. If you explicitly enable Pro iCloud sync, Shield backs up complete restorable document packages to your private CloudKit database; CloudKit encrypts private assets."}},"es":{"stringUnit":{"state":"translated","value":"El procesamiento permanece en el dispositivo. Si activas iCloud Pro, Shield guarda paquetes completos y restaurables en tu CloudKit privado; CloudKit cifra los recursos privados."}}}},
    "settings_faq_2_question" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"Can OCR find every sensitive field?"}},"es":{"stringUnit":{"state":"translated","value":"¿Puede el OCR encontrar todos los datos sensibles?"}}}},
    "settings_faq_2_answer" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"No. OCR suggestions can miss content or mark the wrong region. Image quality, language, layout, handwriting, and document variation all matter. Always review every page and the final export."}},"es":{"stringUnit":{"state":"translated","value":"No. Las sugerencias pueden omitir contenido o marcar una zona incorrecta. Influyen calidad, idioma, diseño, escritura y variaciones. Revisa siempre cada página y la exportación final."}}}},
    "settings_faq_3_question" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"What does verified export mean?"}},"es":{"stringUnit":{"state":"translated","value":"¿Qué significa exportación verificada?"}}}},
    "settings_faq_3_answer" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"Shield rasterizes secure PDF output and checks the generated file for recoverable text, annotations, metadata, and OCR residue. Verification confirms those technical checks, not that every sensitive area was selected. Human review remains essential."}},"es":{"stringUnit":{"state":"translated","value":"Shield rasteriza el PDF seguro y comprueba texto recuperable, anotaciones, metadatos y residuos OCR. La verificación confirma esas pruebas, no que se seleccionaran todos los datos. La revisión humana sigue siendo esencial."}}}},
    "settings_faq_4_question" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"How do I restore Shield Pro?"}},"es":{"stringUnit":{"state":"translated","value":"¿Cómo restauro Shield Pro?"}}}},
    "settings_faq_4_answer" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"Open the Shield Pro purchase screen and choose Restore purchases while signed in with the Apple Account used for the original purchase. Active subscriptions and the lifetime unlock are verified through StoreKit."}},"es":{"stringUnit":{"state":"translated","value":"Abre la pantalla Shield Pro y elige Restaurar compras con la cuenta Apple usada originalmente. StoreKit verifica suscripciones activas y el desbloqueo vitalicio."}}}},
    "settings_faq_5_question" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"How do I cancel a subscription?"}},"es":{"stringUnit":{"state":"translated","value":"¿Cómo cancelo una suscripción?"}}}},
    "settings_faq_5_answer" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"Manage it in iOS Settings under your Apple Account and Subscriptions. Cancel at least 24 hours before renewal. Deleting Shield does not cancel the subscription."}},"es":{"stringUnit":{"state":"translated","value":"Gestiónala en Ajustes de iOS, dentro de tu cuenta Apple y Suscripciones. Cancela al menos 24 horas antes de renovar. Eliminar Shield no cancela la suscripción."}}}},
    "settings_faq_6_question" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"What happens if I forget my PIN?"}},"es":{"stringUnit":{"state":"translated","value":"¿Qué ocurre si olvido mi PIN?"}}}},
    "settings_faq_6_answer" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"Shield cannot recover a forgotten PIN or device-bound encryption key from a server. Keep your device passcode and Apple Account secure, and retain required original documents outside Shield."}},"es":{"stringUnit":{"state":"translated","value":"Shield no puede recuperar desde un servidor un PIN olvidado ni una clave vinculada al dispositivo. Protege el código y la cuenta Apple, y conserva fuera de Shield los originales necesarios."}}}},
    "settings_faq_7_question" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"How can I delete my data?"}},"es":{"stringUnit":{"state":"translated","value":"¿Cómo puedo borrar mis datos?"}}}},
    "settings_faq_7_answer" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"Delete individual projects or use Delete all documents under Security and privacy. You can also disable the optional iCloud index. Removing the app deletes its local container subject to iOS backup behavior."}},"es":{"stringUnit":{"state":"translated","value":"Elimina proyectos o usa Eliminar todos en Seguridad y privacidad. También puedes desactivar el índice de iCloud. Desinstalar borra el contenedor local según el funcionamiento de las copias de iOS."}}}},
    "settings_faq_8_question" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"What should I include in a support message?"}},"es":{"stringUnit":{"state":"translated","value":"¿Qué debo incluir en un mensaje de soporte?"}}}},
    "settings_faq_8_answer" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"Describe the steps, expected result, actual result, device model, iOS version, and Shield version. Never attach an unredacted document, PIN, recovery secret, or screenshot containing sensitive personal information."}},"es":{"stringUnit":{"state":"translated","value":"Describe pasos, resultado esperado y real, modelo, versión de iOS y de Shield. Nunca adjuntes documentos sin redactar, PIN, secretos ni capturas con información personal sensible."}}}}
  },
  "version" : "1.0"
}
