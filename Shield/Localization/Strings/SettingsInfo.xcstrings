    "settings_icloud_detail" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"Synchronize complete, restorable Shield documents through your private iCloud database."}},"es":{"stringUnit":{"state":"translated","value":"Sincroniza documentos completos y restaurables de Shield mediante tu base privada de iCloud."}}}},
    "settings_icloud_minimized_note" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"Complete private document backup and restore"}},"es":{"stringUnit":{"state":"translated","value":"Copia y restauración privada de documentos completos"}}}},
    "settings_icloud_privacy_explanation" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"After you opt in, Shield stores complete document packages as private CloudKit assets. CloudKit encrypts private assets, and Shield re-encrypts restored files in local protected storage."}},"es":{"stringUnit":{"state":"translated","value":"Tras activarlo, Shield guarda paquetes completos como recursos privados de CloudKit. CloudKit cifra los recursos privados y Shield vuelve a cifrar los archivos restaurados en el almacenamiento local protegido."}}}},
    "settings_icloud_pro_subtitle" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"View Pro options to enable complete private backup"}},"es":{"stringUnit":{"state":"translated","value":"Consulta las opciones Pro para activar la copia privada completa"}}}},
