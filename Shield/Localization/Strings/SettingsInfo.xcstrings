    "settings_support_actions" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"Help options"}},"es":{"stringUnit":{"state":"translated","value":"Opciones de ayuda"}}}},
    "settings_support_before_contact_body" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"Never attach an unredacted identity document, financial record, medical file, PIN, or recovery secret. Describe the issue and include only non-sensitive screenshots if needed."}},"es":{"stringUnit":{"state":"translated","value":"Nunca adjuntes documentos de identidad, archivos financieros o médicos sin redactar, PIN ni secretos de recuperación. Describe el problema e incluye solo capturas sin datos sensibles si es necesario."}}}},
    "settings_support_before_contact_title" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"Protect your information"}},"es":{"stringUnit":{"state":"translated","value":"Protege tu información"}}}},
    "settings_support_intro" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"Find answers, report a problem, or suggest an improvement."}},"es":{"stringUnit":{"state":"translated","value":"Encuentra respuestas, informa de un problema o sugiere una mejora."}}}},
    "settings_support_response_body" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"Support will answer through the configured contact channel. Response times are not guaranteed. App Store billing and refund decisions are handled by Apple."}},"es":{"stringUnit":{"state":"translated","value":"Soporte responderá por el canal de contacto configurado. Los plazos no están garantizados. Apple gestiona las decisiones de facturación y reembolso del App Store."}}}},
    "settings_support_response_title" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"What to expect"}},"es":{"stringUnit":{"state":"translated","value":"Qué puedes esperar"}}}},
