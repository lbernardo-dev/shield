    "settings_support_unavailable_message" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"The final support email has not been configured yet. Add it before release to enable feedback."}},"es":{"stringUnit":{"state":"translated","value":"El correo definitivo de soporte aún no está configurado. Añádelo antes del lanzamiento para activar los comentarios."}}}},
    "settings_support_unavailable_title" : {"localizations":{"en":{"stringUnit":{"state":"translated","value":"Support email pending"}},"es":{"stringUnit":{"state":"translated","value":"Correo de soporte pendiente"}}}},
